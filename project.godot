; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;    [section] ; section goes in brackets
;    param=value ; assign values to parameters

config_version=5

[application]

config/name="Flint's Quest: Hearts and Houses"
config/description="2D side-scrolling platformer inspired by Alex Kidd"
run/main_scene="res://scenes/ui/MainMenu.tscn"
config/features=PackedStringArray("4.4", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://scripts/autoloads/GameManager.gd"
SaveSystem="*res://scripts/autoloads/SaveSystem.gd"
AudioManager="*res://scripts/autoloads/AudioManager.gd"
ScoreManager="*res://scripts/autoloads/ScoreManager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[layer_names]

2d_physics/layer_1="World"
2d_physics/layer_2="Player"
2d_physics/layer_3="Enemies"
2d_physics/layer_4="Items"
2d_physics/layer_5="PlayerHitbox"
2d_physics/layer_6="EnemyHitbox"

[rendering]

renderer/rendering_method="forward_plus"
renderer/rendering_method.mobile="gl_compatibility"
